{
    "compilerOptions": {
        "target": "es2016",
        "module": "commonjs",
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "skipLibCheck": true,
        "rootDir": "./src",
        "rootDirs": [
            "./src/app",
            "./src/notify",
            "./src/lang"
        ],
        "outDir": "./dist"
    },
    "include": ["./src/**/*.ts"],
    "exclude": ["./node_modules"]
}
